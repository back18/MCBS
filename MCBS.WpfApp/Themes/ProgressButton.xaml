<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:MCBS.WpfApp.CustomControls">

    <Style x:Key="ButtonProgressBarStyle" TargetType="{x:Type ProgressBar}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ProgressBar}">
                    <Grid>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Determinate" />
                                <VisualState x:Name="Indeterminate">
                                    <Storyboard RepeatBehavior="Forever">
                                        <PointAnimationUsingKeyFrames Storyboard.TargetName="Animation"
                                                                       Storyboard.TargetProperty="(UIElement.RenderTransformOrigin)">
                                            <EasingPointKeyFrame KeyTime="0" Value="-0.5,0.5" />
                                            <EasingPointKeyFrame KeyTime="0:0:1" Value="0.5,0.5" />
                                            <EasingPointKeyFrame KeyTime="0:0:2" Value="1.5,0.5" />
                                        </PointAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <Rectangle Name="PART_Track" Fill="{TemplateBinding Background}" />
                        <Grid x:Name="PART_Indicator" HorizontalAlignment="Left">
                            <Rectangle Name="Indicator" Fill="{TemplateBinding Foreground}" />
                            <Rectangle Name="Animation" Fill="{TemplateBinding Foreground}"
                                       RenderTransformOrigin="0.5,0.5" Visibility="Collapsed">
                                <UIElement.RenderTransform>
                                    <ScaleTransform ScaleX="0.25" />
                                </UIElement.RenderTransform>
                            </Rectangle>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ProgressBar.IsIndeterminate" Value="True">
                            <Setter TargetName="Indicator" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="Animation" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ProgressButton 默认样式 -->
    <Style TargetType="{x:Type controls:ProgressButton}">
        <Setter Property="IsTabStop" Value="True" />
        <Setter Property="Width" Value="Auto" />
        <Setter Property="MinWidth" Value="{Binding ActualHeight, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="15 0" />
        <Setter Property="IndicatorBackground" Value="#28000000" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ProgressButton}">
                    <controls:ClippingBorder x:Name="LayoutRoot"
                                             Background="{TemplateBinding Background}"
                                             BorderThickness="{TemplateBinding BorderThickness}"
                                             BorderBrush="{TemplateBinding BorderBrush}"
                                             CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid>
                            <ProgressBar Name="ProgressBar"
                                         Minimum="0" Maximum="1"
                                         Value="{TemplateBinding Progress}"
                                         Background="#00FFFFFF"
                                         Foreground="{TemplateBinding IndicatorBackground}"
                                         Visibility="Collapsed"
                                         Style="{StaticResource ButtonProgressBarStyle}" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            <Rectangle Name="PressedLayer" Height="3" VerticalAlignment="Top"
                                       Fill="#24000000" Visibility="Collapsed" />
                        </Grid>
                    </controls:ClippingBorder>
                    <ControlTemplate.Triggers>
                        <!-- 鼠标悬停 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="LayoutRoot" Property="Background"
                                    Value="{Binding HoverBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="LayoutRoot" Property="BorderBrush"
                                    Value="{Binding HoverBorderBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Trigger>
                        <!-- 按下 -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="LayoutRoot" Property="Background"
                                    Value="{Binding PressedBackground, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="LayoutRoot" Property="BorderBrush"
                                    Value="{Binding PressedBorderBrush, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="PressedLayer" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PressedLayer" Property="Effect">
                                <Setter.Value>
                                    <BlurEffect RenderingBias="Performance" Radius="5" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <!-- 忙碌状态（不确定进度） -->
                        <Trigger Property="IsBusy" Value="{x:Null}">
                            <Setter Property="IsHitTestVisible" Value="False" />
                            <Setter TargetName="ProgressBar" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ProgressBar" Property="IsIndeterminate" Value="True" />
                        </Trigger>
                        <!-- 忙碌状态（确定进度） -->
                        <Trigger Property="IsBusy" Value="True">
                            <Setter Property="IsHitTestVisible" Value="False" />
                            <Setter TargetName="ProgressBar" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!-- 运行状态 （消除禁用视觉效果）-->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsEnabled" Value="False" />
                                <Condition Property="IsBusy" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter Property="Opacity" Value="0.5" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- 主题颜色触发器 -->
        <Style.Triggers>
            <Trigger Property="Theme" Value="Default">
                <Setter Property="Background" Value="#FFFFFF" />
                <Setter Property="BorderBrush" Value="#D5D5D5" />
                <Setter Property="HoverBackground" Value="#EBEBEB" />
                <Setter Property="HoverBorderBrush" Value="#ADADAD" />
                <Setter Property="PressedBackground" Value="#EBEBEB" />
                <Setter Property="PressedBorderBrush" Value="#ADADAD" />
                <Setter Property="Foreground" Value="#424754" />
            </Trigger>
            <Trigger Property="Theme" Value="Primary">
                <Setter Property="Background" Value="#409EFF" />
                <Setter Property="BorderBrush" Value="#2D8CF0" />
                <Setter Property="HoverBackground" Value="#2D8CF0" />
                <Setter Property="HoverBorderBrush" Value="#2479C4" />
                <Setter Property="PressedBackground" Value="#2681D0" />
                <Setter Property="PressedBorderBrush" Value="#2064A2" />
            </Trigger>
            <Trigger Property="Theme" Value="Success">
                <Setter Property="Background" Value="#5CB85C" />
                <Setter Property="BorderBrush" Value="#4CAE4C" />
                <Setter Property="HoverBackground" Value="#449D44" />
                <Setter Property="HoverBorderBrush" Value="#398439" />
                <Setter Property="PressedBackground" Value="#398439" />
                <Setter Property="PressedBorderBrush" Value="#255625" />
            </Trigger>
            <Trigger Property="Theme" Value="Info">
                <Setter Property="Background" Value="#5BC0DE" />
                <Setter Property="BorderBrush" Value="#46B8DA" />
                <Setter Property="HoverBackground" Value="#31B0D5" />
                <Setter Property="HoverBorderBrush" Value="#269ABC" />
                <Setter Property="PressedBackground" Value="#269ABC" />
                <Setter Property="PressedBorderBrush" Value="#1B6D85" />
            </Trigger>
            <Trigger Property="Theme" Value="Warning">
                <Setter Property="Background" Value="#F0AD4E" />
                <Setter Property="BorderBrush" Value="#EEA236" />
                <Setter Property="HoverBackground" Value="#EC971F" />
                <Setter Property="HoverBorderBrush" Value="#D58512" />
                <Setter Property="PressedBackground" Value="#D58512" />
                <Setter Property="PressedBorderBrush" Value="#985F0D" />
            </Trigger>
            <Trigger Property="Theme" Value="Danger">
                <Setter Property="Background" Value="#D9534F" />
                <Setter Property="BorderBrush" Value="#D43F3A" />
                <Setter Property="HoverBackground" Value="#C9302C" />
                <Setter Property="HoverBorderBrush" Value="#AC2925" />
                <Setter Property="PressedBackground" Value="#AC2925" />
                <Setter Property="PressedBorderBrush" Value="#761C19" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>