<ui:ContentDialog x:Class="MCBS.WpfApp.Views.DialogBoxs.CreateInstanceDialog"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
                  xmlns:lex="http://wpflocalizeextension.codeplex.com"
                  lex:LocalizeDictionary.DesignCulture="zh-CN"
                  lex:ResxLocalizationProvider.DefaultAssembly="MCBS.WpfApp"
                  lex:ResxLocalizationProvider.DefaultDictionary="Lang"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                  xmlns:local="clr-namespace:MCBS.WpfApp.Views.DialogBoxs"
                  xmlns:dialogboxs="clr-namespace:MCBS.WpfApp.ViewModels.DialogBoxs"
                  xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
                  xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
                  xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
                  mc:Ignorable="d" 
                  d:DataContext="{d:DesignInstance Type=dialogboxs:CreateInstanceViewModel}"
                  d:DesignHeight="450" d:DesignWidth="800"
                  PrimaryButtonText="{lex:Loc CreateInstanceDialog_PrimaryButton}"
                  CloseButtonText="{lex:Loc CreateInstanceDialog_CloseButton}"
                  DefaultButton="Primary"
                  Style="{StaticResource ScrollableContentDialogStyle}">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="PrimaryButtonClick">
            <i:InvokeCommandAction Command="{Binding CreateCommand}"
                                   PassEventArgsToCommand="True"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <ikw:SimpleStackPanel Spacing="10">
        <Grid ColumnDefinitions="Auto, *">
            <TextBlock Grid.Column="0"
                       Text="{lex:Loc CreateInstanceDialog_Title}"
                       FontSize="24"
                       FontWeight="Bold"/>
            <ToggleButton Grid.Column="1"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          IsChecked="{Binding IsServer}">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton"
                           BasedOn="{StaticResource {x:Type ToggleButton}}">
                        <Setter Property="Content" Value="{lex:Loc CreateInstanceDialog_Client}" />
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Content" Value="{lex:Loc CreateInstanceDialog_Server}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
            </ToggleButton>
        </Grid>

        <TextBox ui:ControlHelper.Header="{lex:Loc CreateInstanceDialog_InstanceName}"
                 Text="{Binding InstanceName}"/>
        <ikw:SimpleStackPanel Spacing="10">
            <ikw:SimpleStackPanel.Style>
                <Style TargetType="ikw:SimpleStackPanel">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsServer}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ikw:SimpleStackPanel.Style>
            <TextBox ui:ControlHelper.Header="{lex:Loc CreateInstanceDialog_ServerAddress}"
                     Text="{Binding ServerAddress}"/>
            <ui:NumberBox ui:ControlHelper.Header="{lex:Loc CreateInstanceDialog_ServerPort}"
                          Text="{Binding ServerPort}"
                          Minimum="0"
                          Maximum="65535"
                          HorizontalAlignment="Stretch"/>
        </ikw:SimpleStackPanel>
        <TextBox ui:ControlHelper.Header="{lex:Loc CreateInstanceDialog_Version}"
                 Text="{Binding MinecraftVersion}"/>
        <TextBox ui:ControlHelper.Header="{lex:Loc CreateInstanceDialog_Path}"
                 Text="{Binding MinecraftPath}"/>
        <Button Content="{lex:Loc CreateInstanceDialog_SelectFolder}"
                Margin="0, 16, 0, -16"
                Height="32"
                HorizontalAlignment="Stretch"
                Command="{Binding SelectInstanceCommand}"/>
    </ikw:SimpleStackPanel>
</ui:ContentDialog>
