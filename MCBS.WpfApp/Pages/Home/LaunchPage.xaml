<ui:Page x:Class="MCBS.WpfApp.Pages.Home.LaunchPage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:lex="http://wpflocalizeextension.codeplex.com"
         lex:LocalizeDictionary.DesignCulture="zh-CN"
         lex:ResxLocalizationProvider.DefaultAssembly="MCBS.WpfApp"
         lex:ResxLocalizationProvider.DefaultDictionary="Lang"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MCBS.WpfApp.Pages.Home"
         xmlns:viewmodels="clr-namespace:MCBS.WpfApp.ViewModels.Home"
         xmlns:pages="clr-namespace:MCBS.WpfApp.Pages.Home"
         xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
         xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
         xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
         mc:Ignorable="d" 
         d:DesignHeight="450" d:DesignWidth="800"
         d:DataContext="{d:DesignInstance Type=viewmodels:LaunchViewModel}"
         Title="{lex:Loc Title_LaunchPage}">

    <Grid ColumnDefinitions="1*, 3*">
        <Grid Grid.Column="0"
              RowDefinitions="*, Auto">
            <ListBox Grid.Row="0"
                     SelectedItem="{Binding CurrentInstance}"
                     ItemsSource="{Binding InstanceList}"
                     ItemTemplate="{StaticResource MinecraftInstanceItemTemplate}"
                     Margin="5, 5, 5, 0"/>

            <ikw:SimpleStackPanel Grid.Row="1"
                                  Margin="5"
                                  Spacing="5">
                <Button Content="{lex:Loc LaunchPage_ManageInstances}"
                        Height="32"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Command="{Binding PageNavigateCommand}"
                        CommandParameter="{x:Type pages:InstanceManagePage}"/>
                <Button Content="{lex:Loc LaunchPage_InstanceResources}"
                        Height="32"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Command="{Binding PageNavigateCommand}"
                        CommandParameter="{x:Type pages:InstanceResourcePage}"/>
                <Button Content="{lex:Loc LaunchPage_ManageFfmpeg}"
                        Height="32"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"/>
            </ikw:SimpleStackPanel>
        </Grid>
        <Grid Grid.Column="1"
              RowDefinitions="1* 3*, 1*">
            <Grid Grid.Row="0">
                <TextBlock Text="Minecraft Block Screen"
                           FontSize="36"
                           FontWeight="Bold"
                           VerticalAlignment="Top"
                           HorizontalAlignment="Left"
                           Margin="20,20,0,0"/>
            </Grid>
            <ikw:SimpleStackPanel Grid.Row="1"
                                  Margin="10"
                                  Spacing="10"
                                  Visibility="{Binding CurrentInstance, Converter={StaticResource NullToVisibilityConverter}}">
                <TextBlock Text="{lex:Loc LaunchPage_CurrentInstance}"
                           FontSize="20"
                           FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding CurrentInstance.InstanceName}"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock FontSize="16"
                               FontWeight="Bold"
                               Margin="8,0,0,0"
                               Foreground="White"
                               Background="DeepSkyBlue"
                               Padding="6,2"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{lex:Loc InstanceType_Client}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentInstance.IsServer}" Value="True">
                                        <Setter Property="Text" Value="{lex:Loc InstanceType_Server}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
                <TextBlock Text="{Binding CurrentInstance.MinecraftVersion}"
                           FontSize="16"
                           FontWeight="Bold"/>
                <TextBlock Text="{Binding CurrentInstance.MinecraftPath}"
                           FontSize="16"/>
            </ikw:SimpleStackPanel>
            <Grid Grid.Row="2">
                <Button Content="{lex:Loc LaunchPage_LaunchInstance}"
                        Width="240"
                        Height="60"
                        FontSize="18"
                        FontWeight="Bold"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,20"/>
            </Grid>
        </Grid>
    </Grid>
</ui:Page>
