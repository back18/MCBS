<ui:Page x:Class="MCBS.WpfApp.Pages.Home.InstanceManagePage"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:lex="http://wpflocalizeextension.codeplex.com"
         lex:LocalizeDictionary.DesignCulture="zh-CN"
         lex:ResxLocalizationProvider.DefaultAssembly="MCBS.WpfApp"
         lex:ResxLocalizationProvider.DefaultDictionary="Lang"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:local="clr-namespace:MCBS.WpfApp.Pages.Home"
         xmlns:viewmodels="clr-namespace:MCBS.WpfApp.ViewModels.Home"
         xmlns:ikw="http://schemas.inkore.net/lib/ui/wpf"
         xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
         xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
         mc:Ignorable="d" 
         d:DesignHeight="450" d:DesignWidth="800"
         d:DataContext="{d:DesignInstance Type=viewmodels:InstanceManageViewModel}"
         Title="{lex:Loc Title_InstanceManagePage}"
         Loaded="Page_Loaded">

    <Grid ColumnDefinitions="1*, 3*">
        <Grid Grid.Column="0"
              RowDefinitions="*, Auto">
            <ListBox Grid.Row="0"
                     SelectedItem="{Binding CurrentInstance}"
                     ItemsSource="{Binding InstanceList}"
                     ItemTemplate="{StaticResource MinecraftInstanceItemEditTemplate}"
                     Margin="5, 5, 5, 0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <ikw:SimpleStackPanel Grid.Row="1"
                                  Margin="5"
                                  Spacing="5">
                <Button Content="{lex:Loc InstanceManage_AddInstance}"
                        Height="32"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Command="{Binding CreateInstanceCommand}"/>
                <Button Content="{lex:Loc InstanceManage_RefreshList}"
                        Height="32"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        Command="{Binding RefreshListCommand}"/>
            </ikw:SimpleStackPanel>
        </Grid>
        <Grid Grid.Column="1">
            <Frame x:Name="CurrentInstanceSettingsFrame"
                   Margin="5"
                   JournalOwnership="OwnsJournal"
                   NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</ui:Page>
